{% extends 'layout/layout.html.twig' %}

{% block content %}
    <div class="w-screen p-10 text-center">
        <h1 class="text-2xl	text-sky-950 my-6">{{ 'Device.create'|trans }}</h1>
        {{ form_start(form) }}
        {{ form_row(form.is_current, {
            label: 'Form.field.is_current'|trans,
            row_class: 'my-3 min-w-[350px] flex justify-center items-center gap-3',
            label_class: 'block',
            widget_class: 'px-1 h-[30px] w-[30px] border border-stone-800 shadow-input text-center',
        }) }}

        <button type="submit" class="rounded-sm	py-3 px-8 mt-3
                        bg-stone-600 text-stone-200 hover:bg-stone-400 hover:text-stone-50
                        transition-all duration-200 ease-in"
        >
            {{ 'Form.field.save_device'|trans }}
        </button>
        {{ form_end(form) }}
    </div>
{% endblock %}

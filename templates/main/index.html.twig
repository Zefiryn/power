{% extends 'layout/layout.html.twig' %}

{% block content %}
    <div class="flex flex-col items-center justify-center w-screen h-screen">
        <div class="relative">
            <img src="{{ asset('images/main/meter-main.jpg') }}" alt="Symfony!"/>
            <form type="POST" action="{{ path('login', {_locale: app.request.locale}) }}"
                  class="block absolute w-2/3 min-w-20 top-[calc(66.666%-5rem)] mx-[calc((100%-66.666667%)/2)] text-center">
                <input
                    class="w-full h-12 shadow-md rounded shadow-slate-500"
                    name="password" id="password" type="password" placeholder="{{ 'Form.field.password'|trans }}"/>
                <button type="submit" class="rounded-sm	py-3 px-8 mt-3
                    bg-[#FEA524] text-zinc-800 hover:bg-[#FEBA57] hover:text-zinc-600
                    transition-all duration-200 ease-in"
                >
                    {{ 'Form.field.submit_login'|trans }}
                </button>
            </form>
        </div>
        <h1 class="text-sky-900 text-6xl">{{ 'Application.name'|trans }}</h1>
    </div>
{% endblock %}

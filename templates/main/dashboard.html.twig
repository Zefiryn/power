{% extends 'layout/layout.html.twig' %}

{% block content %}
    <div class="pt-14 px-2 lg:pt-10 lg:px-0 text-center w-full lg:w-max lg:min-w-[600px] mx-auto">
        <div class="flex flex-row justify-between gap-[100px] items-center mb-5">
            <h2 class="text-2xl">{{ 'Dashboard.header'|trans }}</h2>
            {{ include('reading/add_button.html.twig') }}
        </div>
        <table class="table-auto border-spacing-4 border-collapse mx-auto shadow w-full">
            <thead class="bg-stone-800">
            <tr class="text-zinc-200">
                <th class="border-0 border-slate-600 px-6 py-2 w-1/3">{{ 'Dashboard.table.date'|trans }}</th>
                <th class="border-0 border-slate-600 px-6 py-2 w-1/3">{{ 'Dashboard.table.value'|trans }}</th>
                <th class="border-0 border-slate-600 px-6 py-2 w-1/3">{{ 'Dashboard.table.change'|trans }}</th>
            </tr>
            </thead>
            <tbody class="bg-zinc-100">
            {% for reading in readings %}
                <tr>
                    <td class="
                            {% if loop.first == false %}border-t border-stone-300{% endif %}
                            {% if loop.index is divisible by(2) %}bg-[#e4dfdb]{% endif %} px-6 py-2
                    ">
                        {{ reading.date }}
                    </td>
                    <td class="
                            {% if loop.first == false %}border-t border-stone-300{% endif %}
                            {% if loop.index is divisible by(2) %}bg-[#e4dfdb]{% endif %} px-6 py-2
                    ">
                        {{ '%.1f'|format(reading.value / 10) }}
                    </td>
                    <td class="
                            {% if loop.first == false %}border-t border-stone-300{% endif %}
                            {% if loop.index is divisible by(2) %}bg-[#e4dfdb]{% endif %} px-6 py-2
                    ">
                        {{ reading.usage ? reading.usage / 10 : '&mdash;' }}
                        <span class="text-[0.7rem]">kWh</span>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="my-5 mx-0 flex flex-row justify-between">
            <span class="inline-block">{{ 'Reading.summary.label'|trans }}:</span>
            <ul class="text-right">
                <li>
                    <span class="text-sm">{{ 'Reading.summary.sum'|trans }}:</span>
                    <span class="font-bold font-['Montserrat'] inline-block w-[140px] lg:w-[90px] w-content">
                        {{ summary.sum / 10 }}
                        <span class="text-[0.7rem] font-['Comfortaa'] font-normal">kWh</span>
                    </span>
                </li>
                <li>
                    <span class="text-sm">{{ 'Reading.summary.average'|trans }}:</span>
                    <span class="font-bold font-['Montserrat'] inline-block w-[140px] lg:w-[90px] w-content">
                        {{ summary.avg / 10 }}
                        <span class="text-[0.7rem] font-['Comfortaa'] font-normal">kWh</span>
                    </span>
                </li>
                <li>
                    <span class="text-sm">{{ 'Reading.summary.median'|trans }}:</span>
                    <span class="font-bold font-['Montserrat'] inline-block w-[140px] lg:w-[90px] w-content">
                        {{ summary.median / 10 }}
                        <span class="text-[0.7rem] font-['Comfortaa'] font-normal">kWh</span>
                    </span>
                </li>
            </ul>
        </div>
    </div>
{% endblock %}

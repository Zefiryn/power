
{% extends 'layout/layout.html.twig' %}

{% block content %}
    <div class="pt-14 px-2 lg:pt-10 lg:px-12 text-center w-full lg:min-w-[600px] mx-auto mb-[10px]">
        <h2 class="text-2xl">{{ 'Analysis.header'|trans }}</h2>

        {# Date Range Selector #}
        <form action="{{ path('analysis') }}" method="get" class="flex justify-end items-center space-x-4 p-4 bg-gray-50 rounded-lg shadow-sm mb-8">
            <div>
                <label for="start_date" class="block text-sm font-medium text-gray-700">{{ 'Analysis.start_date'|trans }}</label>
                <input type="date" id="start_date" name="start_date" value="{{ start_date }}" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-indigo-500 focus:border-indigo-500">
            </div>
            <div>
                <label for="end_date" class="block text-sm font-medium text-gray-700">{{ 'Analysis.end_date'|trans }}</label>
                <input type="date" id="end_date" name="end_date" value="{{ end_date }}" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-indigo-500 focus:border-indigo-500">
            </div>
            <button type="submit" class="px-6 py-2 transition duration-150 ease-in-out">
                {{ 'Analysis.search'|trans }}
            </button>
        </form>
        {# End Date Range Selector #}

        <div class="w-full h-[600px]">
            {{ render_chart(chart) }}
        </div>
    </div>

{% endblock %}